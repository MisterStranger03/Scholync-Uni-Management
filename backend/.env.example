# Copy this file to .env and fill in your values

MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

JWT_SECRET=change_me_to_a_long_random_secret

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Comma-separated frontend origins (defaults to localhost:4200 if blank)
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Used to secure the Vercel OTP serverless function
VERCEL_APP_URL=https://your-frontend.vercel.app
INTERNAL_API_KEY=change_me_to_a_long_random_secret

# Email (used in local dev only; production goes through Vercel)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# Superadmin CMS credentials (env-only, not stored in DB)
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=change_me
SUPER_ADMIN_JWT_SECRET=change_me_to_a_different_long_random_secret

NODE_ENV=production
PORT=3000
